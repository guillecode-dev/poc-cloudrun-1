# ============================================================
# bff-spa — variables de entorno
# Copiar a .env para desarrollo local (nunca versionar .env)
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development

# ── Azure Entra ID ────────────────────────────────────────────
AUTH_TENANT=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AUTH_AUTHORITY=https://login.microsoftonline.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/v2.0
# AUTH_AUDIENCE: el clientId de la API registrada (api://<clientId>)
AUTH_AUDIENCE=api://yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
AUTH_CLIENT_ID=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy

# ── Firestore ────────────────────────────────────────────────
FIRESTORE_PROJECT_ID=my-gcp-project-id

# ── Cloud SQL / PostgreSQL ───────────────────────────────────
# Producción: formato projects/<project>/locations/<region>/instances/<instance>
DB_INSTANCE=projects/my-project/locations/us-central1/instances/my-instance
DB_NAME=poc_db
DB_USER=bff_user
DB_PASSWORD=super-secret-password

# Desarrollo local (usados cuando NODE_ENV != production)
DB_HOST=localhost
DB_PORT=5432

# ── Sesión ───────────────────────────────────────────────────
SESSION_DURATION_MIN=60
SESSION_SLIDING=true
SESSION_MAX_MIN=240

# ── CORS (separado por comas) ─────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300
